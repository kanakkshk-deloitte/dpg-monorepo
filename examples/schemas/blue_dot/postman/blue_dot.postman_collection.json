            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_network\": \"{{network}}\",\n  \"item_domain\": \"{{provider_domain}}\",\n  \"item_type\": \"{{provider_item_type}}\",\n  \"item_state\": {\n    \"jobProviderName\": \"Blue Jobs Pvt Ltd\",\n    \"role\": \"Retail associate\",\n    \"jobProviderLocation\": \"Bengaluru\",\n    \"hiringManagerName\": \"Nisha Rao\",\n    \"hiringManagerPhoneNumber\": \"9876501234\",\n    \"hiringManagerEmail\": \"nisha@example.com\",\n    \"positions\": 3,\n    \"natureOfJob\": \"Full-time\",\n    \"salaryMin\": 15000,\n    \"salaryMax\": 22000,\n    \"candidateExperienceType\": \"Fresher\",\n    \"minEducationalInstitute\": \"College\",\n    \"workExperienceYears\": \"0\",\n    \"lastRoleHeld\": \"Fresher\"\n  }\n}"
            },
            "url": {
              "raw": "{{provider_instance_url}}/api/v1/item/create",
              "host": [
                "{{provider_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "item",
                "create"
              ]
