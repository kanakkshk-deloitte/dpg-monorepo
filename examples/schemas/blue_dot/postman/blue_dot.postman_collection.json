            "description": "Creates a blue_dot provider job posting item."
          }
        }
      ]
    },
    {
      "name": "Blue Dot Actions",
      "description": "Schema-valid blue_dot apply/invite actions.",
      "item": [
        {
          "name": "Seeker Applies To Provider",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action_type\": \"apply\",\n  \"source_item\": {\n    \"item_network\": \"blue_dot\",\n    \"item_domain\": \"seeker\",\n    \"item_type\": \"profile_1.0\",\n    \"item_id\": \"{{seeker_item_id}}\"\n  },\n  \"target_item\": {\n    \"item_network\": \"blue_dot\",\n    \"item_domain\": \"provider\",\n    \"item_type\": \"job_posting_1.0\",\n    \"item_id\": \"{{provider_item_id}}\",\n    \"item_instance_url\": \"{{provider_instance_url}}\"\n  },\n  \"requirements_snapshot\": {\n    \"role\": \"Retail associate\",\n    \"age\": 24,\n    \"workExperience\": \"Fresher\"\n  }\n}"
            },
            "url": {
              "raw": "{{seeker_instance_url}}/api/v1/action/perform",
              "host": [
                "{{seeker_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "action",
                "perform"
              ]
            },
            "description": "Creates a blue_dot apply action from seeker to provider."
          }
        },
        {
          "name": "Provider Invites Seeker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action_type\": \"apply\",\n  \"source_item\": {\n    \"item_network\": \"blue_dot\",\n    \"item_domain\": \"provider\",\n    \"item_type\": \"job_posting_1.0\",\n    \"item_id\": \"{{provider_item_id}}\"\n  },\n  \"target_item\": {\n    \"item_network\": \"blue_dot\",\n    \"item_domain\": \"seeker\",\n    \"item_type\": \"profile_1.0\",\n    \"item_id\": \"{{seeker_item_id}}\",\n    \"item_instance_url\": \"{{seeker_instance_url}}\"\n  },\n  \"requirements_snapshot\": {\n    \"role\": \"Retail associate\",\n    \"interview_time\": \"2026-05-20T10:00:00.000Z\",\n    \"interview_mode\": \"online\",\n    \"message_to_candidate\": \"We would like to speak with you.\"\n  }\n}"
            },
            "url": {
              "raw": "{{provider_instance_url}}/api/v1/action/perform",
              "host": [
                "{{provider_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "action",
                "perform"
              ]
            },
            "description": "Creates a blue_dot provider-to-seeker invite action."
          }
        }
      ]
    },
    {
      "name": "Instance-to-Instance Diagnostics",
      "description": "Direct calls for APIs normally used internally between API instances.",
      "item": [
        {
          "name": "Fetch Network Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/network/item/fetch?item_network={{network}}&item_domain={{domain}}&item_type={{item_type}}&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "item",
                "fetch"
              ],
              "query": [
                {
                  "key": "item_network",
                  "value": "{{network}}"
                },
                {
                  "key": "item_domain",
                  "value": "{{domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{item_type}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Aggregates matching items across configured instances for a network/domain."
          }
        },
        {
          "name": "Fetch Local Items On Instance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_network\": \"{{target_item_network}}\",\n  \"item_domain\": \"{{target_item_domain}}\",\n  \"item_type\": \"{{target_item_type}}\",\n  \"limit\": 20,\n  \"offset\": 0\n}"
            },
            "url": {
              "raw": "{{target_instance_url}}/api/v1/network/item/fetch_local",
              "host": [
                "{{target_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "item",
                "fetch_local"
              ]
            },
            "description": "Directly fetches matching local items from one concrete instance."
          }
        },
        {
          "name": "Perform Network Action On Target Instance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action_type\": \"{{action_type}}\",\n  \"source_item\": {\n    \"item_network\": \"{{source_item_network}}\",\n    \"item_domain\": \"{{source_item_domain}}\",\n    \"item_type\": \"{{source_item_type}}\",\n    \"item_id\": \"{{source_item_id}}\",\n    \"item_instance_url\": \"{{source_instance_url}}\"\n  },\n  \"target_item\": {\n    \"item_network\": \"{{target_item_network}}\",\n    \"item_domain\": \"{{target_item_domain}}\",\n    \"item_type\": \"{{target_item_type}}\",\n    \"item_id\": \"{{target_item_id}}\",\n    \"item_instance_url\": \"{{target_instance_url}}\"\n  },\n  \"source_item_owner\": \"{{source_item_owner}}\",\n  \"requirements_snapshot\": {\n    \"example\": \"replace with schema-valid requirements_snapshot\"\n  }\n}"
            },
            "url": {
              "raw": "{{target_instance_url}}/api/v1/network/action/perform",
              "host": [
                "{{target_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "action",
                "perform"
              ]
            },
            "description": "Direct target-instance action API for diagnostics; normal clients should call Perform Action."
          }
        }
      ]
    }
  ]
}
