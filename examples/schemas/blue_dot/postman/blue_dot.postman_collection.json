            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_network\": \"{{network}}\",\n  \"item_domain\": \"{{seeker_domain}}\",\n  \"item_type\": \"{{seeker_item_type}}\",\n  \"item_state\": {\n    \"name\": \"Asha Worker\",\n    \"gender\": \"Female\",\n    \"location\": \"Bengaluru\",\n    \"age\": 24,\n    \"phone\": \"9876543210\",\n    \"workExperience\": \"Fresher\",\n    \"workExperienceYearsConditional\": \"0\",\n    \"highestQualificationOrSkill\": \"College\",\n    \"natureOfJobsInterestedIn\": \"Full-time\",\n    \"nameOfJobRolesInterestedIn\": \"Retail associate\",\n    \"otherHelpNeeded\": \"Training\"\n  }\n}"
