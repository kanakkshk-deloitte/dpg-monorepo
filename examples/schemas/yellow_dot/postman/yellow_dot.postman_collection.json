  "item": [
    {
      "name": "Auth",
      "description": "Unified OTP authentication requests. Run against the instance in base_url; when domains are hosted separately, authenticate against each host before creating or updating items there.",
      "item": [
        {
          "name": "Check User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phone_number}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/unified-otp/check-user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "unified-otp",
                "check-user"
              ]
            },
            "description": "Checks whether the configured email or phone number already belongs to a user on the selected instance. Run this before requesting an OTP when exercising the auth flow."
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"name\": \"{{user_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/unified-otp/request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "unified-otp",
                "request"
              ]
            },
            "description": "Requests a login or signup OTP for the configured identity. In local development with CREATE_TEST_OTP=true, use the otp collection variable in Verify OTP."
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Verify OTP returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const setCookie = pm.response.headers.get('set-cookie');",
                  "if (setCookie) {",
                  "  pm.collectionVariables.set('session_cookie', setCookie);",
                  "}",
                  "",
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('auth_token', data.token);",
                  "if (data.user?.id) pm.collectionVariables.set('user_id', data.user.id);",
                  "if (data.user?.id) pm.collectionVariables.set('source_item_owner', data.user.id);",
                  "if (data.user?.email) pm.collectionVariables.set('user_email', data.user.email);",
                  "if (data.user?.phoneNumber) pm.collectionVariables.set('user_phone', data.user.phoneNumber);",
                  "if (data.user?.name) pm.collectionVariables.set('user_display_name', data.user.name);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"name\": \"{{user_name}}\",\n  \"otp\": \"{{otp}}\",\n  \"rememberMe\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/unified-otp/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "unified-otp",
                "verify"
              ]
            },
            "description": "Verifies the OTP, creates a Better Auth session on the selected host, and stores returned user/session fields into collection variables for later item/action calls."
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/get-session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "get-session"
              ]
            },
            "description": "Reads the current Better Auth session from the Postman cookie jar for the selected host. Use it to confirm that the instance has an authenticated session before creating or updating items."
          }
        }
      ]
    },
    {
