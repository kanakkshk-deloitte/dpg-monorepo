    {
      "name": "Instance-to-Instance Network Calls",
      "description": "Direct diagnostics for APIs normally called between DPG instances. These requests use explicit source/target instance variables so deployments can run student and tutor domains on different hosts.",
      "item": [
        {
          "name": "Fetch Network Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/network/item/fetch?item_network={{network}}&item_domain={{domain}}&item_type={{item_type}}&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "item",
                "fetch"
              ],
              "query": [
