                  "key": "network",
                  "value": "{{network}}"
                },
                {
                  "key": "domain",
                  "value": "{{domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{item_type}}"
                }
              ]
            },
            "description": "Returns cached schemas known to this API instance, filtered by the selected network, domain, and item type variables."
          }
        },
        {
          "name": "Fetch Student Item Schema",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{student_instance_url}}/api/v1/network/schema/{{network}}/{{student_domain}}/{{student_item_type}}",
              "host": [
