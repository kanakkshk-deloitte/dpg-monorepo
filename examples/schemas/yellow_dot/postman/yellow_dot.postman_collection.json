                  "key": "item_network",
                  "value": "{{network}}"
                },
                {
                  "key": "item_domain",
                  "value": "{{domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{item_type}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
