              ]
            },
            "description": "Updates the student item identified by student_item_id on the configured student instance. Use this after Create Student Item, or replace student_item_id with an existing item id."
          }
        },
        {
          "name": "Fetch My Student Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{student_instance_url}}/api/v1/item/fetch?item_network={{network}}&item_domain={{student_domain}}&item_type={{student_item_type}}&limit=20&offset=0",
              "host": [
                "{{student_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "item",
                "fetch"
              ],
              "query": [
                {
                  "key": "item_network",
                  "value": "{{network}}"
                },
                {
                  "key": "item_domain",
                  "value": "{{student_domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{student_item_type}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Fetches authenticated user-owned student items from the configured student instance. This is the client-facing, user-scoped item fetch API."
          }
        },
        {
          "name": "Create Tutor Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create tutor item returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.item_id) {",
                  "  pm.collectionVariables.set('tutor_item_id', data.item_id);",
                  "  pm.collectionVariables.set('target_item_network', pm.collectionVariables.get('network'));",
                  "  pm.collectionVariables.set('target_item_domain', pm.collectionVariables.get('tutor_domain'));",
                  "  pm.collectionVariables.set('target_item_type', pm.collectionVariables.get('tutor_item_type'));",
                  "  pm.collectionVariables.set('target_item_id', data.item_id);",
                  "  pm.collectionVariables.set('target_instance_url', pm.collectionVariables.get('tutor_instance_url'));",
                  "  pm.collectionVariables.set('target_instance_name', pm.collectionVariables.get('tutor_instance_name'));",
                  "  pm.collectionVariables.set('target_base_url', pm.collectionVariables.get('tutor_instance_url'));",
                  "}",
                  "const userId = pm.collectionVariables.get('user_id');",
                  "if (userId) {",
                  "  pm.collectionVariables.set('tutor_item_owner', userId);",
                  "  pm.collectionVariables.set('target_item_owner', userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
