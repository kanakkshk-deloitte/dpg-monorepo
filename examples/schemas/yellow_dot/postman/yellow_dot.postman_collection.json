    {
      "name": "Actions",
      "description": "Client-facing action APIs for both allowed yellow_dot directions. Replace student_item_id or tutor_item_id with existing item IDs when testing against pre-existing records.",
      "item": [
        {
          "name": "Fetch My Actions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/action/fetch?ownership_role=all&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "action",
                "fetch"
              ],
              "query": [
                {
                  "key": "ownership_role",
                  "value": "all"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Returns actions visible to the authenticated user on the selected instance. Use ownership_role=initiated, received, or all depending on the perspective being inspected."
          }
        },
        {
          "name": "Student Connects To Tutor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Student to tutor action returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.action_id) pm.collectionVariables.set('action_id', data.action_id);",
                  "if (data.action_status) pm.collectionVariables.set('action_status', data.action_status);",
                  "if (typeof data.update_count === 'number') pm.collectionVariables.set('update_count', String(data.update_count));",
