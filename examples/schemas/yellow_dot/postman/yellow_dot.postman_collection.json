                "{{network}}",
                "{{student_domain}}",
                "{{student_item_type}}"
              ]
            },
            "description": "Fetches the concrete yellow_dot student profile schema used to validate Create Student Item and Update Student Item request bodies."
          }
        },
        {
          "name": "Fetch Tutor Item Schema",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tutor_instance_url}}/api/v1/network/schema/{{network}}/{{tutor_domain}}/{{tutor_item_type}}",
              "host": [
                "{{tutor_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "schema",
                "{{network}}",
                "{{tutor_domain}}",
                "{{tutor_item_type}}"
              ]
            },
            "description": "Fetches the concrete yellow_dot individual_tutor_weera_counsellor profile schema used to validate tutor item request bodies."
          }
        },
        {
          "name": "Refetch Schemas",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/network/refetch_schemas",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "refetch_schemas"
              ]
            },
            "description": "Refreshes network schema cache entries on the selected instance. Run after changing local or remote network schema configuration."
          }
        }
      ]
    },
    {
      "name": "Items",
      "description": "Client-facing item APIs separated by yellow_dot domain. Each create/update request uses that domain instance URL so student and tutor domains can be hosted on different deployments.",
      "item": [
        {
          "name": "Create Student Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create student item returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.item_id) {",
                  "  pm.collectionVariables.set('student_item_id', data.item_id);",
                  "  pm.collectionVariables.set('item_id', data.item_id);",
                  "  pm.collectionVariables.set('source_item_network', pm.collectionVariables.get('network'));",
                  "  pm.collectionVariables.set('source_item_domain', pm.collectionVariables.get('student_domain'));",
                  "  pm.collectionVariables.set('source_item_type', pm.collectionVariables.get('student_item_type'));",
                  "  pm.collectionVariables.set('source_item_id', data.item_id);",
                  "  pm.collectionVariables.set('source_instance_url', pm.collectionVariables.get('student_instance_url'));",
                  "  pm.collectionVariables.set('source_instance_name', pm.collectionVariables.get('student_instance_name'));",
                  "}",
                  "const userId = pm.collectionVariables.get('user_id');",
                  "if (userId) {",
                  "  pm.collectionVariables.set('student_item_owner', userId);",
                  "  pm.collectionVariables.set('source_item_owner', userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_network\": \"{{network}}\",\n  \"item_domain\": \"{{student_domain}}\",\n  \"item_type\": \"{{student_item_type}}\",\n  \"item_state\": {\n    \"Student ID\": \"stu-001\",\n    \"Full Name\": \"{{user_display_name}}\",\n    \"Phone Number\": \"9876543210\",\n    \"Email Address\": \"{{email}}\",\n    \"Location\": \"Bengaluru\",\n    \"Grade\": \"Class XI\",\n    \"Academic Stream\": \"Science\",\n    \"Service Looking For\": \"Subject Tutoring\"\n  }\n}"
            },
            "url": {
              "raw": "{{student_instance_url}}/api/v1/item/create",
              "host": [
                "{{student_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "item",
                "create"
              ]
            },
            "description": "Creates a student profile item on the configured student instance. The test script stores student_item_id and also updates the generic source item variables so this new student can initiate actions."
          }
        },
        {
          "name": "Update Student Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_state\": {\n    \"Student ID\": \"stu-001\",\n    \"Full Name\": \"{{user_display_name}} Updated\",\n    \"Phone Number\": \"9876543210\",\n    \"Email Address\": \"{{email}}\",\n    \"Location\": \"Bengaluru\",\n    \"Grade\": \"Class XII\",\n    \"Academic Stream\": \"Science\",\n    \"Service Looking For\": \"Subject Tutoring\"\n  }\n}"
            },
            "url": {
              "raw": "{{student_instance_url}}/api/v1/item/{{student_item_id}}",
              "host": [
                "{{student_instance_url}}"
              ],
              "path": [
                "api",
