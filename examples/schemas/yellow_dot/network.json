{
  "name": "onest_yellow_dot",
  "display_name": "Yellow Dot",
  "description": "Education focused DOT.",
  "schema_standard": "https://json-schema.org/draft/2020-12/schema",
  "domains": [
    {
      "name": "student",
      "description": "Learners on the network.",
      "minimum_cache_ttl_seconds": 300,
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Student Profile 1.0",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Student ID",
            "Full Name",
            "Phone Number",
            "Email Address",
            "Location",
            "Grade",
            "Academic Stream",
            "Service Looking For"
          ],
          "properties": {
            "Student ID": {
              "type": "string",
              "minLength": 1
            },
            "Full Name": {
              "type": "string",
              "minLength": 1
            },
            "Phone Number": {
              "type": "string",
              "pattern": "^[0-9]{10}$",
              "private": true
            },
            "Email Address": {
              "type": "string",
              "format": "email",
              "private": true
            },
            "Location": {
              "type": "string",
              "minLength": 1
            },
            "Grade": {
              "type": "string",
              "enum": [
                "Class XI",
                "Class XII",
                "Post-XII"
              ]
            },
            "Academic Stream": {
              "type": "string",
              "enum": [
                "Science",
                "Commerce",
                "Arts",
                "Other"
              ]
            },
            "Service Looking For": {
              "type": "string",
              "enum": [
                "Subject Tutoring",
                "Admission Guidance",
                "Career Counseling",
                "Skills Workshop"
              ]
            }
          }
        }
      }
    },
    {
      "name": "individual_tutor_weera_counsellor",
      "description": "Individual tutors, WEERA members, and counsellors on the network.",
      "minimum_cache_ttl_seconds": 300,
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Individual Tutor / WEERA / Counsellor Profile 1.0",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Tutor ID",
            "Full Name",
            "Phone Number",
            "Email Address",
            "Location",
            "Coverage Radius (km)",
            "Service Offered",
            "Grade Bands Served",
            "Academic Streams Served"
          ],
          "properties": {
            "Tutor ID": {
              "type": "string",
              "minLength": 1
            },
            "Full Name": {
              "type": "string",
              "minLength": 1
            },
            "Phone Number": {
              "type": "string",
              "pattern": "^[0-9]{10}$",
              "private": true
            },
            "Email Address": {
              "type": "string",
              "format": "email",
              "private": true
            },
            "Location": {
              "type": "string",
              "minLength": 1
            },
            "Coverage Radius (km)": {
              "type": "number",
              "minimum": 0
            },
            "Service Offered": {
              "type": "string",
              "enum": [
                "Subject Tutoring",
                "Test Preparation",
                "Career Counseling",
                "Skills Workshop"
              ]
            },
            "Grade Bands Served": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "Class XI",
                  "Class XII",
                  "Post-XII"
                ]
              }
            },
            "Academic Streams Served": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "Science",
                  "Commerce",
                  "Arts",
                  "Other"
                ]
              }
            }
          }
        }
      }
    }
  ],
  "instances": [
    {
      "domain_name": "student",
      "instance_name": "Yellow Dot Student",
      "instance_url": "https://ubi-backend1.onest.dhiway.net",
      "custom_item_schema_urls": {}
    },
    {
      "domain_name": "individual_tutor_weera_counsellor",
      "instance_name": "Yellow Dot Tutor",
      "instance_url": "https://ubi-backend1.onest.dhiway.net",
      "custom_item_schema_urls": {}
    }
  ],
  "actions": {
    "connect": {
      "description": "Defines which domains can connect to which other domains, what requirement payload they send, and what event payload is returned.",
      "interactions": [
        {
          "from_network": "onest_yellow_dot",
          "from_domain": "student",
          "to_network": "onest_yellow_dot",
          "to_domain": "individual_tutor_weera_counsellor",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Individual Tutor Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "Service Looking For",
              "Grade",
              "Academic Stream",
              "What are you looking to achieve?"
            ],
            "properties": {
              "Service Looking For": {
                "type": "string",
                "enum": [
                  "Subject Tutoring",
                  "Admission Guidance",
                  "Career Counseling",
                  "Skills Workshop"
                ]
              },
              "Grade": {
                "type": "string",
                "enum": [
                  "Class XI",
                  "Class XII",
                  "Post-XII"
                ]
              },
              "Academic Stream": {
                "type": "string",
                "enum": [
                  "Science",
                  "Commerce",
                  "Arts",
                  "Other"
                ]
              },
              "What are you looking to achieve?": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Individual Tutor Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "remark"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "created",
                  "accepted",
                  "rejected"
                ]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "onest_yellow_dot",
          "from_domain": "individual_tutor_weera_counsellor",
          "to_network": "onest_yellow_dot",
          "to_domain": "student",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Individual Tutor To Student Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "Introduction Message"
            ],
            "properties": {
              "Introduction Message": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Individual Tutor To Student Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "remark"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "created",
                  "accepted",
                  "rejected"
                ]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        }
      ]
    }
  }
}
