{
  "name": "yellow_dot",
  "display_name": "Yellow Dot",
  "description": "Education focused DOT with inter-network citizen actions.",
  "schema_standard": "https://json-schema.org/draft/2020-12/schema",
  "cross_network_origins": [
    {
      "name": "blue_dot",
      "display_name": "Blue Dot",
      "schema_url": "https://registry.example.com/schemas/inter-network-action/blue_dot/network.json"
    }
  ],
  "domains": [
    {
      "name": "student",
      "description": "Learners on the network.",
      "minimum_cache_ttl_seconds": 300,
      "item_schemas": {
        "citizen_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "https://registry.example.com/schemas/inter-network-action/yellow_dot/student/citizen_1.0.json",
          "title": "Citizen 1.0",
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "location"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "location": {
              "type": "object",
              "additionalProperties": false,
              "required": ["city", "state", "country"],
              "properties": {
                "city": {
                  "type": "string",
                  "minLength": 1
                },
                "state": {
                  "type": "string",
                  "minLength": 1
                },
                "country": {
                  "type": "string",
                  "minLength": 1
                },
                "postal_code": {
                  "type": "string"
                }
              }
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "phone": {
              "type": "string"
            }
          }
        },
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Student Profile 1.0",
          "unevaluatedProperties": false,
          "allOf": [
            {
              "$ref": "#/$defs/citizen_1_0"
            },
            {
              "type": "object",
              "required": ["grade", "preferred_subject"],
              "properties": {
                "grade": {
                  "type": "string",
                  "enum": ["8", "9", "10", "11", "12"]
                },
                "preferred_subject": {
                  "type": "string"
                }
              }
            }
          ],
          "$defs": {
            "citizen_1_0": {
              "type": "object",
              "required": ["name", "location"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "location": {
                  "type": "object",
                  "required": ["city", "state", "country"],
                  "properties": {
                    "city": {
                      "type": "string",
                      "minLength": 1
                    },
                    "state": {
                      "type": "string",
                      "minLength": 1
                    },
                    "country": {
                      "type": "string",
                      "minLength": 1
                    },
                    "postal_code": {
                      "type": "string"
                    }
                  }
                },
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "phone": {
                  "type": "string"
                }
              }
            }
          }
        },
        "profile_1.1": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Student Profile 1.1",
          "unevaluatedProperties": false,
          "allOf": [
            {
              "$ref": "#/$defs/citizen_1_0"
            },
            {
              "type": "object",
              "required": ["grade", "language", "preferred_subject"],
              "properties": {
                "grade": {
                  "type": "string",
                  "enum": ["8", "9", "10", "11", "12"]
                },
                "language": {
                  "type": "string",
                  "minLength": 1
                },
                "preferred_subject": {
                  "type": "string"
                }
              }
            }
          ],
          "$defs": {
            "citizen_1_0": {
              "type": "object",
              "required": ["name", "location"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "location": {
                  "type": "object",
                  "required": ["city", "state", "country"],
                  "properties": {
                    "city": {
                      "type": "string",
                      "minLength": 1
                    },
                    "state": {
                      "type": "string",
                      "minLength": 1
                    },
                    "country": {
                      "type": "string",
                      "minLength": 1
                    },
                    "postal_code": {
                      "type": "string"
                    }
                  }
                },
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "phone": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "tutor",
      "description": "Tutors on the network.",
      "minimum_cache_ttl_seconds": 300,
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Tutor Profile 1.0",
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "subjects", "experience_years"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "subjects": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "experience_years": {
              "type": "integer",
              "minimum": 0
            },
            "teaching_mode": {
              "type": "string",
              "enum": ["online", "offline", "hybrid"]
            }
          }
        }
      }
    },
    {
      "name": "coaching_center",
      "description": "Coaching centers on the network.",
      "minimum_cache_ttl_seconds": 300,
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Coaching Center Profile 1.0",
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "city", "programs"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "city": {
              "type": "string"
            },
            "programs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "seats_available": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  ],
  "instances": [
    {
      "domain_name": "student",
      "instance_name": "Yellow Dot Student Localhost",
      "instance_url": "http://localhost:2742",
      "custom_item_schema_urls": {}
    },
    {
      "domain_name": "student",
      "instance_name": "Yellow Dot Student",
      "instance_url": "http://127.0.0.1:2742",
      "custom_item_schema_urls": {}
    },
    {
      "domain_name": "tutor",
      "instance_name": "Yellow Dot Tutor Localhost",
      "instance_url": "http://localhost:2742",
      "custom_item_schema_urls": {}
    },
    {
      "domain_name": "tutor",
      "instance_name": "Yellow Dot Tutor",
      "instance_url": "http://127.0.0.1:2742",
      "custom_item_schema_urls": {}
    }
  ],
  "actions": {
    "connect": {
      "description": "Defines which citizens and student profiles can connect to education providers.",
      "interactions": [
        {
          "from_network": "yellow_dot",
          "from_domain": "student",
          "from_items": ["citizen_1.0", "profile_1.0", "profile_1.1"],
          "to_network": "yellow_dot",
          "to_domain": "tutor",
          "to_items": ["profile_1.0"],
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Tutor Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": ["subject", "goal"],
            "properties": {
              "subject": {
                "type": "string"
              },
              "goal": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Tutor Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "remark"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pending", "accepted", "rejected"]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "yellow_dot",
          "from_domain": "student",
          "from_items": ["citizen_1.0", "profile_1.0", "profile_1.1"],
          "to_network": "yellow_dot",
          "to_domain": "coaching_center",
          "to_items": ["profile_1.0"],
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Coaching Center Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": ["program", "goal"],
            "properties": {
              "program": {
                "type": "string"
              },
              "goal": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Coaching Center Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "remark"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pending", "accepted", "rejected"]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "apply": {
      "description": "Declares that Yellow Dot citizens can apply to Blue Dot job postings.",
      "interactions": [
        {
          "from_network": "yellow_dot",
          "from_domain": "student",
          "from_items": ["citizen_1.0", "profile_1.0", "profile_1.1"],
          "to_network": "blue_dot",
          "to_domain": "provider",
          "to_items": ["job_posting_1.0", "job_posting_1.1"],
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Yellow Dot Citizen Job Application Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": ["job_id", "cover_note", "eligibility_confirmation"],
            "properties": {
              "job_id": {
                "type": "string",
                "minLength": 1
              },
              "cover_note": {
                "type": "string",
                "minLength": 1
              },
              "eligibility_confirmation": {
                "type": "boolean",
                "description": "Confirms the citizen meets the job eligibility requirements."
              },
              "resume_url": {
                "type": "string",
                "format": "uri"
              },
              "portfolio_url": {
                "type": "string",
                "format": "uri"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Yellow Dot Citizen Job Application Event",
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "remark"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["submitted", "shortlisted", "rejected"]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        }
      ]
    }
  }
}
