{
  "info": {
    "name": "DPG Single Domain API",
    "_postman_id": "dpg-single-domain-api-collection",
    "description": "Generic Postman collection for one DPG API instance serving one network/domain. Use schema-specific collections for concrete example networks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:2742"
    },
    {
      "key": "email",
      "value": "demo@example.com"
    },
    {
      "key": "phone_number",
      "value": "+911234567890"
    },
    {
      "key": "user_name",
      "value": "Demo User"
    },
    {
      "key": "otp",
      "value": "777666"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "session_cookie",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "user_email",
      "value": ""
    },
    {
      "key": "user_phone",
      "value": ""
    },
    {
      "key": "user_display_name",
      "value": ""
    },
    {
      "key": "network",
      "value": "example_network"
    },
    {
      "key": "domain",
      "value": "example_domain"
    },
    {
      "key": "item_type",
      "value": "profile_1.0"
    },
    {
      "key": "item_id",
      "value": ""
    },
    {
      "key": "source_item_network",
      "value": "example_network"
    },
    {
      "key": "source_item_domain",
      "value": "example_domain"
    },
    {
      "key": "source_item_type",
      "value": "profile_1.0"
    },
    {
      "key": "source_item_id",
      "value": ""
    },
    {
      "key": "source_instance_url",
      "value": "http://127.0.0.1:2742"
    },
    {
      "key": "source_item_owner",
      "value": ""
    },
    {
      "key": "target_item_network",
      "value": "example_network"
    },
    {
      "key": "target_item_domain",
      "value": "example_domain"
    },
    {
      "key": "target_item_type",
      "value": "profile_1.0"
    },
    {
      "key": "target_item_id",
      "value": ""
    },
    {
      "key": "target_instance_url",
      "value": "http://127.0.0.1:2742"
    },
    {
      "key": "action_type",
      "value": "connect"
    },
    {
      "key": "action_id",
      "value": ""
    },
    {
      "key": "action_status",
      "value": "created"
    },
    {
      "key": "update_count",
      "value": "0"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Unified OTP flow. Run against the instance you are about to create or update items on.",
      "item": [
        {
          "name": "Check User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phone_number}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/unified-otp/check-user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "unified-otp",
                "check-user"
              ]
            },
            "description": "Checks whether a user exists for the configured email or phone number."
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"name\": \"{{user_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/unified-otp/request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "unified-otp",
                "request"
              ]
            },
            "description": "Requests an OTP for login or signup."
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Verify OTP returns 200', function () { pm.response.to.have.status(200); });",
                  "const setCookie = pm.response.headers.get('set-cookie');",
                  "if (setCookie) pm.collectionVariables.set('session_cookie', setCookie);",
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('auth_token', data.token);",
                  "if (data.user?.id) pm.collectionVariables.set('user_id', data.user.id);",
                  "if (data.user?.email) pm.collectionVariables.set('user_email', data.user.email);",
                  "if (data.user?.phoneNumber) pm.collectionVariables.set('user_phone', data.user.phoneNumber);",
                  "if (data.user?.name) pm.collectionVariables.set('user_display_name', data.user.name);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"name\": \"{{user_name}}\",\n  \"otp\": \"{{otp}}\",\n  \"rememberMe\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/unified-otp/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "unified-otp",
                "verify"
              ]
            },
            "description": "Verifies OTP and stores useful auth variables."
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/get-session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "get-session"
              ]
            },
            "description": "Returns the current Better Auth session for the selected instance."
          }
        }
      ]
    },
    {
      "name": "Network Schemas",
      "description": "Schema inspection and cache refresh calls.",
      "item": [
        {
          "name": "Fetch Cached Schemas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/network/schemas?network={{network}}&domain={{domain}}&item_type={{item_type}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "schemas"
              ],
              "query": [
                {
                  "key": "network",
                  "value": "{{network}}"
                },
                {
                  "key": "domain",
                  "value": "{{domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{item_type}}"
                }
              ]
            },
            "description": "Returns cached schemas filtered by the selected variables."
          }
        },
        {
          "name": "Fetch Item Schema",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/network/schema/{{network}}/{{domain}}/{{item_type}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "schema",
                "{{network}}",
                "{{domain}}",
                "{{item_type}}"
              ]
            },
            "description": "Fetches the concrete item schema for the selected domain and item type."
          }
        },
        {
          "name": "Refetch Schemas",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/network/refetch_schemas",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "refetch_schemas"
              ]
            },
            "description": "Reloads configured network schemas and referenced item schemas."
          }
        }
      ]
    },
    {
      "name": "Items",
      "description": "Generic single-domain item calls. Replace item_state to match the schema selected by network/domain/item_type.",
      "item": [
        {
          "name": "Create Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create item returns 201', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "if (data.item_id) { pm.collectionVariables.set('item_id', data.item_id); pm.collectionVariables.set('source_item_id', data.item_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_network\": \"{{network}}\",\n  \"item_domain\": \"{{domain}}\",\n  \"item_type\": \"{{item_type}}\",\n  \"item_state\": {\n    \"example\": \"replace with schema-valid item_state\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/item/create",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "item",
                "create"
              ]
            },
            "description": "Creates an item for the one domain served by this API instance."
          }
        },
        {
          "name": "Fetch My Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/item/fetch?item_network={{network}}&item_domain={{domain}}&item_type={{item_type}}&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "item",
                "fetch"
              ],
              "query": [
                {
                  "key": "item_network",
                  "value": "{{network}}"
                },
                {
                  "key": "item_domain",
                  "value": "{{domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{item_type}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Fetches authenticated user-owned items for the served domain."
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_state\": {\n    \"example\": \"replace with full schema-valid updated item_state\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/item/{{item_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "item",
                "{{item_id}}"
              ]
            },
            "description": "Updates one authenticated user-owned item by id."
          }
        }
      ]
    },
    {
      "name": "Actions And Events",
      "description": "Generic action/event calls. Fill source/target variables from the selected schema and discovered item IDs.",
      "item": [
        {
          "name": "Perform Action",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Perform action returns 201', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "if (data.action_id) pm.collectionVariables.set('action_id', data.action_id);",
                  "if (data.action_status) pm.collectionVariables.set('action_status', data.action_status);",
                  "if (typeof data.update_count === 'number') pm.collectionVariables.set('update_count', String(data.update_count));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action_type\": \"{{action_type}}\",\n  \"source_item\": {\n    \"item_network\": \"{{source_item_network}}\",\n    \"item_domain\": \"{{source_item_domain}}\",\n    \"item_type\": \"{{source_item_type}}\",\n    \"item_id\": \"{{source_item_id}}\"\n  },\n  \"target_item\": {\n    \"item_network\": \"{{target_item_network}}\",\n    \"item_domain\": \"{{target_item_domain}}\",\n    \"item_type\": \"{{target_item_type}}\",\n    \"item_id\": \"{{target_item_id}}\",\n    \"item_instance_url\": \"{{target_instance_url}}\"\n  },\n  \"requirements_snapshot\": {\n    \"example\": \"replace with schema-valid requirements_snapshot\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/action/perform",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "action",
                "perform"
              ]
            },
            "description": "Creates an action from a source item on this instance to a target item on an allowed network instance."
          }
        },
        {
          "name": "Fetch My Actions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/action/fetch?ownership_role=all&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "action",
                "fetch"
              ],
              "query": [
                {
                  "key": "ownership_role",
                  "value": "all"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Fetches actions visible to the authenticated user."
          }
        },
        {
          "name": "Fetch My Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/event/fetch?ownership_role=all&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "event",
                "fetch"
              ],
              "query": [
                {
                  "key": "ownership_role",
                  "value": "all"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Fetches action events visible to the authenticated user."
          }
        }
      ]
    },
    {
      "name": "Instance-to-Instance Diagnostics",
      "description": "Direct calls for APIs normally used internally between API instances.",
      "item": [
        {
          "name": "Fetch Network Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/network/item/fetch?item_network={{network}}&item_domain={{domain}}&item_type={{item_type}}&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "item",
                "fetch"
              ],
              "query": [
                {
                  "key": "item_network",
                  "value": "{{network}}"
                },
                {
                  "key": "item_domain",
                  "value": "{{domain}}"
                },
                {
                  "key": "item_type",
                  "value": "{{item_type}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Aggregates matching items across configured instances for a network/domain."
          }
        },
        {
          "name": "Fetch Local Items On Instance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_network\": \"{{target_item_network}}\",\n  \"item_domain\": \"{{target_item_domain}}\",\n  \"item_type\": \"{{target_item_type}}\",\n  \"limit\": 20,\n  \"offset\": 0\n}"
            },
            "url": {
              "raw": "{{target_instance_url}}/api/v1/network/item/fetch_local",
              "host": [
                "{{target_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "item",
                "fetch_local"
              ]
            },
            "description": "Directly fetches matching local items from one concrete instance."
          }
        },
        {
          "name": "Perform Network Action On Target Instance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action_type\": \"{{action_type}}\",\n  \"source_item\": {\n    \"item_network\": \"{{source_item_network}}\",\n    \"item_domain\": \"{{source_item_domain}}\",\n    \"item_type\": \"{{source_item_type}}\",\n    \"item_id\": \"{{source_item_id}}\",\n    \"item_instance_url\": \"{{source_instance_url}}\"\n  },\n  \"target_item\": {\n    \"item_network\": \"{{target_item_network}}\",\n    \"item_domain\": \"{{target_item_domain}}\",\n    \"item_type\": \"{{target_item_type}}\",\n    \"item_id\": \"{{target_item_id}}\",\n    \"item_instance_url\": \"{{target_instance_url}}\"\n  },\n  \"source_item_owner\": \"{{source_item_owner}}\",\n  \"requirements_snapshot\": {\n    \"example\": \"replace with schema-valid requirements_snapshot\"\n  }\n}"
            },
            "url": {
              "raw": "{{target_instance_url}}/api/v1/network/action/perform",
              "host": [
                "{{target_instance_url}}"
              ],
              "path": [
                "api",
                "v1",
                "network",
                "action",
                "perform"
              ]
            },
            "description": "Direct target-instance action API for diagnostics; normal clients should call Perform Action."
          }
        }
      ]
    }
  ]
}
