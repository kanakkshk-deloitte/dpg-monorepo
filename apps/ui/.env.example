# ─── Map Configuration ───────────────────────────────────────────
# Map provider: leaflet (default), google-maps, mapbox
VITE_MAP_PROVIDER=leaflet

# Google Maps API key (required when VITE_MAP_PROVIDER=google-maps)
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox access token (required when VITE_MAP_PROVIDER=mapbox)
VITE_MAPBOX_ACCESS_TOKEN=

# Geocoding service URL (optional, for pincode → lat/lng conversion)
# Leave empty to use the default free postal pincode API for India
VITE_GEOCODING_API_URL=

# ─── API Configuration ────────────────────────────────────────────
# API base URL for authentication and other endpoints
VITE_API_URL=http://localhost:3000

# Additional API instances (dev mode only, JSON format)
# The dropdown will show these options alongside the default
# Example: {"student":"http://localhost:3001","tutor":"http://localhost:3002"}
VITE_API_URLS=

# Override default API URL (optional)
# If set, this will be used instead of VITE_API_URL as the default option
# VITE_DEFAULT_API_URL=http://localhost:3000

# Show instance selector dropdown in production (for testing)
# Set to 'true' when deploying to Amplify for testing different backends
# VITE_SHOW_INSTANCE_SELECTOR=true

# ─── Network Configuration ─────────────────────────────────────────
# Network id to use (e.g., yellow_dot, blue_dot)
# If empty, shows network selector in sidebar for multi-network setups
# VITE_NETWORK_ID=yellow_dot

# ─── Credential Import Providers ────────────────────────────────────
# Dhiway Wallet configuration
# Required to enable the Dhiway wallet provider in the UI.
VITE_VC_WALLET_URL=
VITE_VC_WALLET_API_KEY=

# DigiLocker configuration
# Required to enable the DigiLocker provider in the UI.
VITE_AGENT_URL=
VITE_AGENT_TOKEN=

# DigiLocker popup callback
# The DigiLocker redirect origin should host the bridge page at:
#   /digilocker-bridge.html
# This repo includes the bridge file at apps/ui/public/digilocker-bridge.html.
