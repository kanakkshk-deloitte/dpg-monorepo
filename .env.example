# package/config/src/secrets.ts manages the calculation for secrets

# Name of the backend service - used by auth layer
INSTANCE_NAME="dpg"

# INSTANCE_ENV:
# set to development for local environment 
# set to production for server environment (domain is linked)
INSTANCE_ENV="development"

# for server environment where a domain is linked to API_PORT enter the domain 
API_DOMAIN='http://localhost'
API_PORT="2742"

# secret for authentication service
AUTH_SECRET="3481d33c5700"
ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"

# Backend identity on the network.
# Format: network/domain and comma separate multiple bindings.
SERVED_DOMAINS="yellow_dot/student"

# Network config source.
# local: load a checked-in JSON file, useful for development
# remote: fetch one or more network config JSON files from NETWORK_CONFIG_URLS
# or derive them from SCHEMA_REGISTRY_URL
NETWORK_CONFIG_SOURCE="local"

# Used when NETWORK_CONFIG_SOURCE=local
NETWORK_CONFIG_LOCAL_FILE="examples/schemas/yellow_dot/network.json"

# Used when NETWORK_CONFIG_SOURCE=remote
# Format: network=url and comma separate multiple mappings
# NETWORK_CONFIG_URLS="yellow_dot=https://registry.example.com/yellow-dot/network.json"
# databases

# PostgreSQL configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="da729670ee354c3e"
POSTGRES_DB="postgresdb"
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT=5432
DATABASE_PORT=5432
# optional override for external postgres
# POSTGRES_URL="postgres://user:password@host:5432/dbname"

# Redis
REDIS_HOST="127.0.0.1"
REDIS_PASSWORD="2389eced416749388305"
REDIS_PORT=5555
# optional override for external redis
# REDIS_URL="redis://:password@host:6379"

NOTIFICATION_SERVICE_ENDPOINT='enter_notification_service_endpoint'
NOTIFICATION_SERVICE_KEY_ID='enter_notification_service_key_id'
NOTIFICATION_SERVICE_SECRET='enter_notification_service_secret'
SMS_TEMPLATE_ID='enter_sms_template_id'

MATCH_SCORE_PROVIDER='dpg_scoring'
DPG_SCORING_ENDPOINT='https://scoring.example.com'
DPG_SCORING_KEY_ID='enter_dpg_scoring_key_id'
DPG_SCORING_SECRET='enter_dpg_scoring_secret'
# optional, defaults to /api/v1/scores/match
# DPG_SCORING_PATH='api/v1/scores/match'
# optional provider payload fields
# DPG_SCORING_VERSION='v1'
# DPG_SCORING_PROMPT_VERSION='match-compatibility-v1'

# Network schema registry
# Supported formats:
# 1. single base URL, which resolves served networks to {base}/{network}/network.json
# 2. explicit network=url mappings for multiple registries or full JSON URLs
# SCHEMA_REGISTRY_URL='https://registry.example.com/schemas/'
SCHEMA_REGISTRY_URL='yellow_dot=https://registry.example.com/schemas/yellow_dot/network.json,blue_dot=https://registry.other.example.com/schemas/blue_dot/network.json'

# Feature Flags value: empty to make false || any string to make true
# Test Auth (Unified-Plugin) 
CREATE_TEST_OTP=false
AUTH_MIDDLEWARE_ENABLED=true
