{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@dpg/*": [
        "./packages/*/src"
      ]
    },
    "strict": true,
    "declaration": true,
    "composite": true,
    "skipLibCheck": true
  }
}