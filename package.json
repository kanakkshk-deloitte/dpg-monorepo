{
  "name": "dpg-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for DPG",
  "main": "index.js",
  "scripts": {
    "dev:api": "node scripts/turbo-with-root-env.mjs run dev --filter=api",
    "dev:docs": "node scripts/turbo-with-root-env.mjs run dev --filter=docs",
    "build:api": "node scripts/turbo-with-root-env.mjs run build --filter=api",
    "build:docs": "node scripts/turbo-with-root-env.mjs run build --filter=docs",
    "preview:api": "node scripts/turbo-with-root-env.mjs run preview --filter=api",
    "preview:docs": "node scripts/turbo-with-root-env.mjs run preview --filter=docs",
    "start:api": "node scripts/turbo-with-root-env.mjs run start --filter=api",
    "start:docs": "node scripts/turbo-with-root-env.mjs run start --filter=docs",
