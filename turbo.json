{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "VITE_*",
    "PUBLIC_*",
    "ASTRO_*"
  ],
  "globalPassThroughEnv": [
    "ALLOWED_ORIGINS",
    "ALLOW_EXTRA_SCHEMA_DATA",
    "API_DOMAIN",
    "API_PORT",
    "AUTH_MIDDLEWARE_ENABLED",
    "AUTH_SECRET",
    "CREATE_TEST_OTP",
    "DATABASE_PORT",
    "DPG_SCORING_*",
    "INSTANCE_ENV",
    "INSTANCE_NAME",
    "MATCH_SCORE_PROVIDER",
    "NETWORK_CONFIG_*",
    "NOTIFICATION_SERVICE_*",
    "POSTGRES_*",
    "REDIS_*",
    "SCHEMA_REGISTRY_URL",
    "SERVED_DOMAINS",
    "SMS_TEMPLATE_ID"
  ],
  "tasks": {
    "build": {
      "inputs": [
        "$TURBO_DEFAULT$"
      ],
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false,
      "persistent": true
    },
    "preview": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "start": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "db:pull": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:push": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:generate": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:migrate": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    },
    "db:studio": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "cache": false
    }
  }
}
